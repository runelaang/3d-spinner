{
  "name": "3d-spinner",
  "version": "0.1.0",
  "description": "A lightweight, customizable 3D spinner for loading, generating, processing, and other waiting states in modern web apps.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "npx serve .",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "spinner",
    "loader",
    "loading",
    "3d",
    "progress"
  ],
  "author": "RuneL",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/runelaang/3d-spinner.git"
  },
  "homepage": "https://github.com/runelaang/3d-spinner#readme",
  "bugs": {
    "url": "https://github.com/runelaang/3d-spinner/issues"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}